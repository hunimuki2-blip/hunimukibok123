{
  "app": "clipvibe",
  "description": "ClipVibe - Video Sharing Platform",
  "start": "node backend/server.js",
  "install": "npm install && cd frontend && npm install",
  "build": "cd frontend && npm run build",
  "static": "frontend/build",
  "env": {
    "NODE_ENV": "production",
    "PORT": "3000"
  },
  "paths": {
    "static": "/frontend/build"
  }
}

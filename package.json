{
  "name": "clipvibe",
  "version": "1.0.0",
  "description": "A video sharing platform - ClipVibe",
  "main": "backend/server.js",
  "scripts": {
    "start": "bash start.sh",
    "start:direct": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "frontend": "cd frontend && npm start",
    "frontend:build": "cd frontend && npm run build",
    "build": "cd frontend && npm install && npm run build",
    "serve": "npx serve -s frontend/build",
    "deploy": "npm run build && npm run start:direct",
    "railway:start": "bash start.sh",
    "cyclic:start": "bash start.sh"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "multer": "^1.4.5-lts.1",
    "nodemon": "^3.0.2",
    "serve": "^14.2.1",
    "uuid": "^9.0.1"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
